---
import SEO from '../components/SEO.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <SEO title={title} description={description} image={image} />
  </head>
  <body class="bg-white text-black min-h-screen flex flex-col items-center antialiased">
    <main class="w-full max-w-[65ch] px-4 md:px-8 py-20 flex-grow">
      <nav class="mb-16">
        <a href="/" class="text-black font-medium hover:underline inline-block">&larr; Back to Home</a>
      </nav>
      <slot />
    </main>
    <footer class="w-full max-w-[65ch] px-4 md:px-8 py-8 border-t border-gray-100 text-sm text-gray-500 mt-20">
      <div class="flex justify-between items-center">
        <span>&copy; {new Date().getFullYear()} Blake Byers</span>
      </div>
    </footer>
  </body>
</html>
